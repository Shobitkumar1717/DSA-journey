public class Main {

	static int countFreqDigit(int n,int d)
    {
        int count=0;
        while(n>0){
            int digit =n%10;
            if(digit==d){
                count++;
            }
             n=n/10;
            
        }
        return count;
        
    }
	
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n= sc.nextInt();
        int d= sc.nextInt();
        System.out.println(countFreqDigit(n,d));
    }
}